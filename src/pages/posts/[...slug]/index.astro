---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import { getPostSlug, getPostUrl } from "@/utils/getPostPaths";
import { getDisplayPostTitle } from "@/utils/postTitle";
import { getPostDescription } from "@/utils/postDescription";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import EditPost from "./_components/EditPost.astro";
import ShareLinks from "./_components/ShareLinks.astro";
import BackButton from "./_components/BackButton.astro";
import BackToTopButton from "./_components/BackToTopButton.astro";
import AdjacentPostNav from "./_components/AdjacentPostNav.astro";
import config from "@/config";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sortedPosts = getSortedPosts(posts);

  return sortedPosts.map((post, index) => ({
    params: { slug: getPostSlug(post.id, post.filePath) },
    props: {
      post,
      prevPost:
        index > 0
          ? {
              id: sortedPosts[index - 1].id,
              title: sortedPosts[index - 1].data.title,
              filePath: sortedPosts[index - 1].filePath,
            }
          : null,
      nextPost:
        index < sortedPosts.length - 1
          ? {
              id: sortedPosts[index + 1].id,
              title: sortedPosts[index + 1].data.title,
              filePath: sortedPosts[index + 1].filePath,
            }
          : null,
    },
  }));
}

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
} | null;

type Props = {
  post: CollectionEntry<"posts">;
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { post, prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;

const {
  title,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;
const displayTitle = getDisplayPostTitle(title);
const description = getPostDescription(post);

const { Content } = await render(post);

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && config.features.dynamicOgImage) {
  const postUrl = getPostUrl(post.id, post.filePath, locale).replace(
    /\/+$/,
    ""
  );
  ogImageUrl = `${postUrl}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;
const hatenaBasename = post.id
  .replace(/^hatenablog\//, "")
  .replace(/\.mdx?$/, "");
---

<PostLayout
  title={`${displayTitle} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
>
  <Header />

  <BackButton />

  <main
    id="main-content"
    class:list={["app-layout", { "mt-8": !config.features.showBackButton }]}
    data-pagefind-body
  >
    <h1
      style={{ viewTransitionName: toTransitionName(displayTitle) }}
      class="text-heading inline-block text-2xl font-bold sm:text-3xl"
    >
      {displayTitle}
    </h1>

    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={[
          "text-muted-foreground max-sm:hidden",
          { hidden: !config.features.editPost?.enabled || hideEditPost },
        ]}
      >
        |
      </span>
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>

    <article
      id="article"
      data-hatena-basename={hatenaBasename}
      class:list={[
        "mt-8 w-full",
        "app-prose max-w-app",
        "prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)",
      ]}
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <BackToTopButton />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <ShareLinks />

    <hr class="my-8 border-dashed" />

    <AdjacentPostNav {prevPost} {nextPost} />
  </main>
  <Footer />
</PostLayout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  async function enhanceBlueskyEmbeds() {
    const article = document.getElementById("article");
    if (!article) return;

    function normalizedCardUrl(value) {
      return String(value || "")
        .trim()
        .replace(/^<|>$/g, "")
        .replace(/\/$/, "");
    }

    function manifestEntry(manifest, href) {
      try {
        const url = new URL(href, window.location.href);
        return (
          manifest[href] ||
          manifest[url.href] ||
          manifest[normalizedCardUrl(href)] ||
          manifest[normalizedCardUrl(url.href)] ||
          {}
        );
      } catch {
        return {};
      }
    }

    async function loadEmbedManifest() {
      try {
        const response = await fetch("/hatena-embeds/manifest.json");
        if (!response.ok) return {};
        return await response.json();
      } catch {
        return {};
      }
    }

    const blocks = Array.from(article.querySelectorAll("blockquote"));
    let foundEmbed = false;

    for (const block of blocks) {
      const postLink = block.querySelector(
        'a[href*="bsky.app/"][href*="/post/"]'
      );
      if (!postLink) continue;

      const authorLink = block.querySelector(
        'a[href*="bsky.app/profile/did:"]'
      );
      if (!authorLink) continue;

      const authorUrl = new URL(authorLink.href);
      const postUrl = new URL(postLink.href);
      const did = authorUrl.pathname.match(/\/profile\/([^/?#]+)/)?.[1];
      const postId = postUrl.pathname.match(/\/post\/([^/?#]+)/)?.[1];
      if (!did || !postId) continue;

      block.classList.add("bluesky-embed");
      block.dataset.blueskyUri = `at://${did}/app.bsky.feed.post/${postId}`;
      block.dataset.blueskyEmbedColorMode = "light";
      foundEmbed = true;

      const next = block.nextElementSibling;
      const duplicateLink = next?.matches("p")
        ? next.querySelector(":scope > a[href*='bsky.app/']")
        : null;
      if (
        duplicateLink &&
        next.textContent.trim() === duplicateLink.textContent.trim()
      ) {
        next.remove();
      }
    }

    const manifest = await loadEmbedManifest();
    const standaloneLinks = Array.from(
      article.querySelectorAll('p > a[href*="bsky.app/"][href*="/post/"]')
    );
    for (const link of standaloneLinks) {
      if (link.closest("section.footnotes, [data-footnotes]")) continue;

      const paragraph = link.parentElement;
      if (!paragraph || paragraph.tagName !== "P") continue;
      const meaningfulNodes = Array.from(paragraph.childNodes).filter(node => {
        return node.nodeType !== Node.TEXT_NODE || node.textContent.trim();
      });
      if (meaningfulNodes.length !== 1 || meaningfulNodes[0] !== link) continue;

      const metadata = manifestEntry(manifest, link.getAttribute("href"));
      if (typeof metadata.blueskyUri !== "string") continue;

      const embed = document.createElement("blockquote");
      embed.className = "bluesky-embed";
      embed.dataset.blueskyUri = metadata.blueskyUri;
      embed.dataset.blueskyEmbedColorMode = "light";

      const fallback = document.createElement("a");
      fallback.href = link.href;
      fallback.textContent = link.textContent?.trim() || link.href;
      embed.append(fallback);

      paragraph.replaceWith(embed);
      foundEmbed = true;
    }

    if (!foundEmbed) return;

    if (window.bluesky?.scan) {
      window.bluesky.scan(article);
      return;
    }

    const script = document.createElement("script");
    script.async = true;
    script.src = "https://embed.bsky.app/static/embed.js";
    script.setAttribute("charset", "utf-8");
    document.body.appendChild(script);
  }
  const blueskyEnhancement = enhanceBlueskyEmbeds();

  async function enhanceHatenaImages() {
    const article = document.getElementById("article");
    if (!article) return;

    let manifest = {};
    try {
      const response = await fetch("/hatena-images/manifest.json");
      if (!response.ok) return;
      manifest = await response.json();
    } catch {
      return;
    }

    const images = Array.from(article.querySelectorAll("img"));
    for (const image of images) {
      const src = image.getAttribute("src");
      if (!src) continue;

      const localSrc = manifest[src];
      if (!localSrc) continue;

      image.dataset.remoteSrc = src;
      image.src = localSrc;

      const link = image.closest("a");
      if (link) {
        try {
          const href = new URL(link.href);
          if (href.hostname === "f.hatena.ne.jp") {
            link.href = localSrc;
            image.classList.add("hatena-fotolife-thumbnail");
          } else if (
            href.hostname === "i.imgur.com" ||
            (href.hostname === "imgur.com" && href.href === src)
          ) {
            link.href = localSrc;
          }
        } catch {
          // Leave non-URL links unchanged.
        }
      }
    }
  }
  enhanceHatenaImages();

  async function repairHatenaTableImages() {
    const article = document.getElementById("article");
    const basename = article?.dataset.hatenaBasename;
    if (!article || !basename) return;

    let manifest = {};
    try {
      const response = await fetch("/hatena-images/table-repairs.json");
      if (!response.ok) return;
      manifest = await response.json();
    } catch {
      return;
    }

    const repairs = manifest[basename];
    if (!Array.isArray(repairs)) return;

    const rows = Array.from(article.querySelectorAll("table tr"));
    for (const repair of repairs) {
      const row = rows[repair.row];
      const cell = row?.children?.[repair.cell];
      if (!cell || cell.querySelector("img")) continue;

      const alt = typeof repair.alt === "string" ? repair.alt : "";
      const localSrc =
        typeof repair.localSrc === "string" ? repair.localSrc : "";
      if (!localSrc || cell.textContent.trim() !== alt) continue;

      const image = document.createElement("img");
      image.src = localSrc;
      image.alt = alt;
      image.loading = "lazy";
      image.className = "hatena-table-image-repair";

      cell.replaceChildren(image);
    }
  }
  repairHatenaTableImages();

  function enhanceHatenaMediaEmbeds() {
    const article = document.getElementById("article");
    if (!article) return;

    const fediverseEmbedHosts = new Set(["mastodon.cloud", "fedibird.com"]);

    function getMediaEmbed(anchor) {
      try {
        const url = new URL(anchor.href);
        const hostname = url.hostname.replace(/^www\./, "");

        if (hostname === "youtube.com" && url.pathname.startsWith("/embed/")) {
          return {
            src: url.href,
            title: "YouTube video",
            provider: "www.youtube.com",
            className: "hatena-media-embed-youtube",
          };
        }

        if (hostname === "speakerdeck.com" && url.pathname.startsWith("/player/")) {
          return {
            src: url.href,
            title: "Speaker Deck presentation",
            provider: "speakerdeck.com",
            className: "hatena-media-embed-speakerdeck",
          };
        }

        if (
          hostname === "w.soundcloud.com" &&
          url.pathname.startsWith("/player/")
        ) {
          return {
            src: url.href,
            title: "SoundCloud audio",
            provider: "soundcloud.com",
            className: "hatena-media-embed-soundcloud",
          };
        }

        if (
          fediverseEmbedHosts.has(hostname) &&
          url.pathname.endsWith("/embed")
        ) {
          return {
            src: url.href,
            title: "Fediverse post",
            provider: hostname,
            className: "hatena-media-embed-fediverse",
          };
        }
      } catch {
        return null;
      }

      return null;
    }

    function isOnlyLinksAndWhitespace(paragraph) {
      return Array.from(paragraph.childNodes).every(node => {
        return (
          node.nodeType === Node.TEXT_NODE
            ? !node.textContent.trim()
            : node.nodeType === Node.ELEMENT_NODE && node.tagName === "A"
        );
      });
    }

    const paragraphs = Array.from(article.querySelectorAll("p"));
    for (const paragraph of paragraphs) {
      if (paragraph.closest("section.footnotes, [data-footnotes]")) continue;
      if (!isOnlyLinksAndWhitespace(paragraph)) continue;

      const anchors = Array.from(paragraph.querySelectorAll("a"));
      const mediaAnchor = anchors.find(anchor => getMediaEmbed(anchor));
      if (!mediaAnchor) continue;

      const media = getMediaEmbed(mediaAnchor);
      if (!media) continue;

      const providerLink =
        anchors.find(anchor => anchor !== mediaAnchor)?.href || mediaAnchor.href;

      const figure = document.createElement("figure");
      figure.className = `hatena-media-embed ${media.className}`;

      const frameWrap = document.createElement("div");
      frameWrap.className = "hatena-media-embed-frame";

      const iframe = document.createElement("iframe");
      iframe.src = media.src;
      iframe.title = media.title;
      iframe.loading = "lazy";
      iframe.allow =
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = "strict-origin-when-cross-origin";

      const caption = document.createElement("figcaption");
      const link = document.createElement("a");
      link.href = providerLink;
      link.target = "_blank";
      link.rel = "noopener noreferrer";
      link.textContent = media.provider;
      caption.append(link);

      frameWrap.append(iframe);
      figure.append(frameWrap, caption);
      paragraph.replaceWith(figure);
    }
  }
  enhanceHatenaMediaEmbeds();

  function normalizeHatenaEmbedPlaceholders() {
    const article = document.getElementById("article");
    if (!article) return;

    function isOnlyLinksAndWhitespace(paragraph) {
      return Array.from(paragraph.childNodes).every(node => {
        return (
          node.nodeType === Node.TEXT_NODE
            ? !node.textContent.trim()
            : node.nodeType === Node.ELEMENT_NODE && node.tagName === "A"
        );
      });
    }

    function localHatenaPostUrl(url) {
      if (url.hostname !== "atsushieno.hatenablog.com") return null;

      const match = url.pathname.match(
        /^\/entry\/(\d{4})\/(\d{2})\/(\d{2})\/(\d{6})\/?$/
      );
      if (!match) return null;

      const [, year, month, day, slug] = match;
      return `/posts/hatenablog/${year}/${month}/${day}/${slug}/`;
    }

    const paragraphs = Array.from(article.querySelectorAll("p"));
    for (const paragraph of paragraphs) {
      if (paragraph.closest("section.footnotes, [data-footnotes]")) continue;
      if (!isOnlyLinksAndWhitespace(paragraph)) continue;

      const anchors = Array.from(paragraph.querySelectorAll("a"));
      if (anchors.length !== 2) continue;

      let embedUrl;
      let canonicalUrl;
      try {
        embedUrl = new URL(anchors[0].href);
        canonicalUrl = new URL(anchors[1].href);
      } catch {
        continue;
      }

      const firstLinkText = anchors[0].textContent.trim();
      const isImportedAutolink =
        firstLinkText.startsWith("http://") ||
        firstLinkText.startsWith("https://");
      const isImportedEmbed =
        isImportedAutolink ||
        embedUrl.pathname.includes("/embed/") ||
        embedUrl.hostname === "w.soundcloud.com" ||
        embedUrl.hostname === "speakerdeck.com" ||
        embedUrl.hostname === "www.youtube.com";
      if (!isImportedEmbed) continue;

      const replacement = document.createElement("a");
      replacement.className = "hatena-embed";
      replacement.href = localHatenaPostUrl(canonicalUrl) || canonicalUrl.href;
      replacement.dataset.hatenaEmbedUrl = canonicalUrl.href;
      replacement.target = "_blank";
      replacement.rel = "noopener noreferrer";

      const title = document.createElement("span");
      title.className = "hatena-embed-title";
      title.textContent = anchors[1].textContent.trim() || canonicalUrl.href;

      const domain = document.createElement("span");
      domain.className = "hatena-embed-domain";
      domain.textContent = canonicalUrl.hostname;

      replacement.append(title, domain);
      paragraph.replaceWith(replacement);
    }
  }
  normalizeHatenaEmbedPlaceholders();

  function enhanceImgurEmbeds() {
    const article = document.getElementById("article");
    if (!article) return;

    const blocks = Array.from(article.querySelectorAll("blockquote"));
    let foundEmbed = false;

    for (const block of blocks) {
      const link = block.querySelector('a[href*="imgur.com/a/"]');
      if (!link) continue;

      let url;
      try {
        url = new URL(link.href);
      } catch {
        continue;
      }

      const albumId = url.pathname.match(/^\/a\/([^/?#]+)/)?.[1];
      if (!albumId) continue;

      const embed = document.createElement("blockquote");
      embed.className = "imgur-embed-pub hatena-imgur-embed";
      embed.dataset.id = `a/${albumId}`;
      embed.dataset.context = "false";

      const embedLink = document.createElement("a");
      embedLink.href = `https://imgur.com/a/${albumId}`;
      embedLink.textContent = link.textContent?.trim() || "View post on imgur.com";
      embed.append(embedLink);

      const next = block.nextElementSibling;
      const duplicateLink = next?.matches("p")
        ? next.querySelector(":scope > a[href*='imgur.com/a/']")
        : null;
      if (
        duplicateLink &&
        next.textContent.trim() === duplicateLink.textContent.trim()
      ) {
        next.remove();
      }

      block.replaceWith(embed);
      foundEmbed = true;
    }

    if (!foundEmbed || document.querySelector('script[src*="s.imgur.com/min/embed.js"]')) {
      return;
    }

    const script = document.createElement("script");
    script.async = true;
    script.src = "https://s.imgur.com/min/embed.js";
    script.setAttribute("charset", "utf-8");
    document.body.appendChild(script);
  }
  enhanceImgurEmbeds();

  async function enhanceHatenaEmbeds() {
    const manifestCacheKey = "hatena-embed-manifest-v1";

    async function loadEmbedManifest() {
      let cachedManifest = {};

      try {
        const cachedValue = window.localStorage?.getItem(manifestCacheKey);
        if (cachedValue) cachedManifest = JSON.parse(cachedValue);
      } catch {
        cachedManifest = {};
      }

      try {
        const response = await fetch("/hatena-embeds/manifest.json");
        if (!response.ok) return cachedManifest;
        const manifest = await response.json();
        try {
          window.localStorage?.setItem(
            manifestCacheKey,
            JSON.stringify(manifest)
          );
        } catch {
          // localStorage can be unavailable or full; the fetched manifest is enough.
        }
        return manifest;
      } catch {
        return cachedManifest;
      }
    }

    function normalizedCardUrl(value) {
      return String(value || "")
        .trim()
        .replace(/^<|>$/g, "")
        .replace(/\/$/, "");
    }

    function isStandaloneLinkCard(anchor) {
      if (anchor.closest("section.footnotes, [data-footnotes]")) return false;

      const parent = anchor.parentElement;
      if (!parent || parent.tagName !== "P") return false;
      if (anchor.querySelector("img")) return false;

      const meaningfulNodes = Array.from(parent.childNodes).filter(node => {
        return node.nodeType !== Node.TEXT_NODE || node.textContent.trim();
      });
      if (meaningfulNodes.length !== 1 || meaningfulNodes[0] !== anchor) {
        return false;
      }

      try {
        const url = new URL(anchor.href);
        const rawLinkText = anchor.textContent.trim();
        const linkText = rawLinkText.replace(/^www\./, "");
        const hostname = url.hostname.replace(/^www\./, "");
        return (
          linkText === hostname ||
          normalizedCardUrl(rawLinkText) === normalizedCardUrl(url.href)
        );
      } catch {
        return false;
      }
    }

    const manifest = await loadEmbedManifest();
    const embeds = Array.from(
      document.querySelectorAll("a.hatena-embed, #article p > a")
    ).filter(embed => {
      return (
        !embed.closest("section.footnotes, [data-footnotes]") &&
        (embed.classList.contains("hatena-embed") || isStandaloneLinkCard(embed))
      );
    });

    for (const embed of embeds) {
      const href = embed.getAttribute("href");
      if (!href) continue;
      const url = new URL(href, window.location.href);
      const metadataHref = embed.getAttribute("data-hatena-embed-url");
      const metadata = metadataHref
        ? manifest[metadataHref] || {}
        : manifest[href] ||
          manifest[url.href] ||
          manifest[normalizedCardUrl(href)] ||
          manifest[normalizedCardUrl(url.href)] ||
          {};

      const title =
        embed.querySelector(".hatena-embed-title")?.textContent?.trim() ||
        embed.textContent?.trim() ||
        href;
      const domain =
        embed.querySelector(".hatena-embed-domain")?.textContent?.trim() ||
        url.hostname;
      const path = decodeURIComponent(url.pathname)
        .replace(/^\/|\/$/g, "")
        .replaceAll("/", " / ");
      const cardTitle =
        metadata.title ||
        (title.replace(/^www\./, "") === domain.replace(/^www\./, "") && path
          ? `${domain} / ${path}`
          : title);

      const card = document.createElement("a");
      card.href = href;
      card.target = "_blank";
      card.rel = "noopener noreferrer";
      card.className = "hatena-link-card";
      card.setAttribute("aria-label", `${cardTitle} (${domain})`);

      const titleEl = document.createElement("span");
      titleEl.className = "hatena-link-card-title";
      titleEl.textContent = cardTitle;

      const body = document.createElement("span");
      body.className = "hatena-link-card-body";

      const text = document.createElement("span");
      text.className = "hatena-link-card-text";
      text.append(titleEl);

      if (metadata.description) {
        const descriptionEl = document.createElement("span");
        descriptionEl.className = "hatena-link-card-description";
        descriptionEl.textContent = metadata.description;
        text.append(descriptionEl);
      }

      body.append(text);

      if (metadata.image) {
        const image = document.createElement("img");
        image.className = "hatena-link-card-image";
        image.src = metadata.image;
        image.alt = "";
        image.loading = "lazy";
        image.addEventListener("error", () => image.remove(), { once: true });
        body.append(image);
      }

      const footer = document.createElement("span");
      footer.className = "hatena-link-card-footer";

      const favicon = document.createElement("img");
      favicon.className = "hatena-link-card-favicon";
      favicon.src = `https://www.google.com/s2/favicons?domain_url=${encodeURIComponent(
        href
      )}&sz=32`;
      favicon.alt = "";
      favicon.loading = "lazy";
      favicon.addEventListener("error", () => favicon.remove(), { once: true });

      const domainEl = document.createElement("span");
      domainEl.textContent = domain;

      footer.append(favicon, domainEl);
      card.append(body, footer);

      const replaceTarget = isStandaloneLinkCard(embed)
        ? embed.parentElement
        : embed;
      replaceTarget?.replaceWith(card);
    }
  }
  blueskyEnhancement.finally(() => enhanceHatenaEmbeds());

  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /** Accessible image lightbox for article images. */
  function initLightbox() {
    const article = document.getElementById("article");
    if (!article) return;

    const prefersReducedMotion = () =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let overlay = null;
    let lastFocused = null;

    // Defer attribute mutations so they don't push the LCP timestamp.
    // Event listeners below use delegation and don't need the attributes to exist yet.
    requestAnimationFrame(() => {
      const images = Array.from(article.querySelectorAll("img"));
      for (const image of images) {
        if (image.closest("a")) continue;
        image.setAttribute("role", "button");
        image.setAttribute("tabindex", "0");
        image.setAttribute("aria-haspopup", "dialog");
        image.setAttribute(
          "aria-label",
          image.alt ? `Zoom image: ${image.alt}` : "Zoom image"
        );
      }
    });

    function open(src, alt, trigger) {
      if (overlay) return;
      lastFocused = trigger ?? document.activeElement;

      overlay = document.createElement("div");
      overlay.setAttribute("role", "dialog");
      overlay.setAttribute("aria-modal", "true");
      overlay.setAttribute(
        "aria-label",
        alt ? `Image preview: ${alt}` : "Image preview"
      );
      overlay.className =
        "fixed inset-0 z-50 flex cursor-zoom-out items-center justify-center bg-black/70 backdrop-blur-sm opacity-0 transition-opacity duration-200 motion-reduce:transition-none";

      const closeButton = document.createElement("button");
      closeButton.type = "button";
      closeButton.setAttribute("aria-label", "Close image preview");
      closeButton.className =
        "absolute end-4 top-4 rounded p-2 text-3xl leading-none text-white";
      closeButton.innerHTML = "&#10005;";
      closeButton.addEventListener("click", close);

      const image = document.createElement("img");
      image.src = src;
      image.alt = "";
      image.className =
        "max-h-[90dvh] max-w-[90dvw] cursor-default object-contain";

      overlay.append(closeButton, image);
      overlay.addEventListener("click", e => {
        if (e.target === overlay && currentScale <= 1) close();
      });

      let currentScale = 1;
      let translateX = 0;
      let translateY = 0;
      let initialDist = 0;
      let initialScale = 1;
      let panStartX = 0;
      let panStartY = 0;
      let panStartTranslateX = 0;
      let panStartTranslateY = 0;
      let lastTapTime = 0;

      function applyTransform() {
        image.style.transform = `scale(${currentScale}) translate(${translateX}px, ${translateY}px)`;
      }

      function resetTransform() {
        currentScale = 1;
        translateX = 0;
        translateY = 0;
        image.style.transform = "";
      }

      overlay.addEventListener(
        "touchstart",
        e => {
          const t = e.touches;
          if (t.length === 2) {
            initialDist = Math.hypot(
              t[1].clientX - t[0].clientX,
              t[1].clientY - t[0].clientY
            );
            initialScale = currentScale;
          } else if (t.length === 1) {
            const now = Date.now();
            if (now - lastTapTime < 300) {
              e.preventDefault();
              if (currentScale > 1) {
                resetTransform();
              } else {
                currentScale = 2;
                translateX = 0;
                translateY = 0;
                applyTransform();
              }
              lastTapTime = 0;
              panStartX = t[0].clientX;
              panStartY = t[0].clientY;
              panStartTranslateX = translateX;
              panStartTranslateY = translateY;
            } else {
              lastTapTime = now;
              if (currentScale > 1) {
                panStartX = t[0].clientX;
                panStartY = t[0].clientY;
                panStartTranslateX = translateX;
                panStartTranslateY = translateY;
              }
            }
          }
        },
        { passive: false }
      );

      overlay.addEventListener(
        "touchmove",
        e => {
          const t = e.touches;
          if (t.length === 2) {
            e.preventDefault();
            const dist = Math.hypot(
              t[1].clientX - t[0].clientX,
              t[1].clientY - t[0].clientY
            );
            currentScale = Math.min(
              4,
              Math.max(1, initialScale * (dist / initialDist))
            );
            applyTransform();
          } else if (t.length === 1) {
            if (currentScale > 1) {
              e.preventDefault();
              translateX =
                panStartTranslateX + (t[0].clientX - panStartX) / currentScale;
              translateY =
                panStartTranslateY + (t[0].clientY - panStartY) / currentScale;
              const maxX = Math.max(
                0,
                (image.clientWidth - overlay.clientWidth / currentScale) / 2
              );
              const maxY = Math.max(
                0,
                (image.clientHeight - overlay.clientHeight / currentScale) / 2
              );
              translateX = Math.min(maxX, Math.max(-maxX, translateX));
              translateY = Math.min(maxY, Math.max(-maxY, translateY));
              applyTransform();
            } else {
              e.preventDefault();
            }
          }
        },
        { passive: false }
      );

      overlay.addEventListener("touchend", e => {
        if (e.touches.length === 0 && currentScale <= 1.05) {
          resetTransform();
        }
      });

      overlay.addEventListener("touchcancel", e => {
        if (e.touches.length === 0 && currentScale <= 1.05) {
          resetTransform();
        }
      });

      document.body.appendChild(overlay);
      document.body.style.overflow = "hidden";
      document.addEventListener("keydown", onKeyDown);
      window.__closeLightbox = close;

      requestAnimationFrame(() => overlay?.classList.add("opacity-100"));
      closeButton.focus();
    }

    function close() {
      if (!overlay) return;
      const el = overlay;
      overlay = null;
      window.__closeLightbox = null;

      document.removeEventListener("keydown", onKeyDown);
      document.body.style.overflow = "";
      lastFocused?.focus();
      lastFocused = null;

      if (prefersReducedMotion()) {
        el.remove();
        return;
      }
      const remove = () => el.remove();
      el.addEventListener("transitionend", remove, { once: true });
      setTimeout(remove, 250); // fallback in case transitionend never fires
      el.classList.remove("opacity-100");
    }

    function onKeyDown(e) {
      if (e.key === "Escape") {
        close();
      } else if (e.key === "Tab") {
        trapFocus(e);
      }
    }

    // Keep keyboard focus inside the open dialog.
    function trapFocus(e) {
      if (!overlay) return;
      const focusables = overlay.querySelectorAll(
        'a[href], button, [tabindex]:not([tabindex="-1"])'
      );
      if (focusables.length === 0) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function triggerFromEvent(e) {
      const image = e.target.closest("img");
      if (!image || !article.contains(image) || image.closest("a")) return null;
      return image;
    }

    function activate(image) {
      open(image.currentSrc || image.src, image.alt, image);
    }

    article.addEventListener("click", e => {
      const image = triggerFromEvent(e);
      if (!image) return;
      e.preventDefault();
      activate(image);
    });

    article.addEventListener("keydown", e => {
      if (e.key !== "Enter" && e.key !== " " && e.key !== "Spacebar") return;
      const image = triggerFromEvent(e);
      if (!image) return;
      e.preventDefault();
      activate(image);
    });
  }
  initLightbox();

  if (!window.__lightboxSwapBound) {
    window.__lightboxSwapBound = true;
    document.addEventListener("astro:before-swap", () =>
      window.__closeLightbox?.()
    );
  }

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
