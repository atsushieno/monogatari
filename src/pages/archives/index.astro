---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostsByGroupCondition } from "./_utils/getPostsByGroupCondition";
import { getPostYear, getPostMonth, monthName } from "./_utils/archiveDate";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Redirect to 404 page if `showArchives` config is false
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (!config.features.showArchives && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const t = useTranslations(locale);

const posts = getSortedPosts(await getCollection("posts"));

const byYear = getPostsByGroupCondition(posts, post => getPostYear(post));
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title={`${t.pages.archivesTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.archivesTitle} pageDesc={t.pages.archivesDesc}>
    <p class="mb-6">
      <a
        href={getRelativeLocaleUrl(locale, "archives/all")}
        class="underline hover:opacity-75"
      >
        &rarr; View all entries on one page
      </a>
    </p>
    {
      years.map(year => {
        const yearGroup = byYear[year];
        const byMonth = getPostsByGroupCondition(yearGroup, post =>
          getPostMonth(post)
        );
        const months = Object.keys(byMonth).sort(
          (a, b) => Number(b) - Number(a)
        );
        return (
          <section class="mb-8">
            <h2 class="text-2xl font-bold">
              <a
                href={getRelativeLocaleUrl(locale, `archives/${year}`)}
                class="hover:underline"
              >
                {year}
              </a>
              <sup class="text-muted-foreground text-sm">{yearGroup.length}</sup>
            </h2>
            <ul class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
              {months.map(month => (
                <li>
                  <a
                    href={getRelativeLocaleUrl(
                      locale,
                      `archives/${year}/${month}`
                    )}
                    class="hover:underline"
                  >
                    {monthName(month, locale)}
                    <sup class="text-muted-foreground text-xs">
                      {byMonth[month].length}
                    </sup>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    }
  </Main>

  <Footer />
</Layout>
