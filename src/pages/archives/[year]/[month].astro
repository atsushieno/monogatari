---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostsByGroupCondition } from "../_utils/getPostsByGroupCondition";
import { getPostYear, getPostMonth, monthName } from "../_utils/archiveDate";
import { useTranslations } from "@/i18n";
import config from "@/config";

export const getStaticPaths = (async () => {
  const posts = getSortedPosts(await getCollection("posts"));
  const byYear = getPostsByGroupCondition(posts, post => getPostYear(post));

  return Object.entries(byYear).flatMap(([year, yearPosts]) => {
    const byMonth = getPostsByGroupCondition(yearPosts, post =>
      getPostMonth(post)
    );
    return Object.entries(byMonth).map(([month, monthPosts]) => ({
      params: { year, month },
      props: { year, month, posts: monthPosts },
    }));
  });
}) satisfies GetStaticPaths;

const { year, month, posts } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const label = `${monthName(month, locale)} ${year}`;
---

<Layout title={`${t.pages.archivesTitle}: ${label} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={`${t.pages.archivesTitle}: ${label}`}>
    <ul>
      {posts.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Footer />
</Layout>
